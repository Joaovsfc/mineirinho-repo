# Servidor
PORT=3001
NODE_ENV=development

# Banco de dados (caminho absoluto ou relativo ao process.cwd())
# Exemplo: ./data/mineirinho.db ou /var/lib/mineirinho/mineirinho.db
DB_PATH=./data/mineirinho.db

# CORS - origens permitidas separadas por vírgula
# Exemplo: http://localhost:8080,http://127.0.0.1:8080,file://
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,file://

# JWT - chave secreta para autenticação (OBRIGATORIO mudar em producao!)
# Gere uma chave aleatória com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROCAR-POR-UMA-CHAVE-SECRETA-ALEATORIA
